<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="GoalOptionButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>

        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>

        <!-- Fondo claro -->
        <item name="backgroundTint">@color/ft_surface</item>
        <!-- Texto -->
        <item name="android:textColor">@color/ft_text_primary</item>

        <!-- Borde -->
        <item name="strokeWidth">2dp</item>
        <item name="strokeColor">@color/ft_border</item>

        <!-- Esquinas -->
        <item name="cornerRadius">14dp</item>

        <!-- Ripple -->
        <item name="rippleColor">@color/ft_surface_alt</item>
    </style>

    <style name="FitTrackSegmentButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/ft_text_primary</item>
        <item name="backgroundTint">@color/ft_surface</item>
        <item name="strokeColor">@color/ft_primary</item>

        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>