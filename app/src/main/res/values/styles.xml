<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="GoalOptionButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>

        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>


        <item name="android:textColor">@color/toggle_button_text</item>

        <item name="backgroundTint">@color/toggle_button_background</item>

        <item name="strokeColor">@color/ft_primary</item>

        <item name="strokeWidth">2dp</item>

        <item name="cornerRadius">16dp</item>

        <item name="android:textAllCaps">false</item>
    </style>

    <style name="FitTrackSegmentButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/toggle_button_text</item>

        <item name="backgroundTint">@color/toggle_button_background</item>

        <item name="strokeColor">@color/ft_primary</item>

        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="MySearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textColorHint">?android:attr/textColorHint</item>
    </style>
</resources>