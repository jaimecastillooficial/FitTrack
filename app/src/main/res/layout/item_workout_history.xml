<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/ft_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvWorkoutDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ft_text_secondary"
                android:textSize="13sp"
                tools:text="2026-05-03" />

            <ImageView
                android:id="@+id/btnDeleteWorkout"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:paddingHorizontal="8dp"
                android:src="@drawable/icon_delete"
                android:contentDescription="Eliminar entrenamiento"
                app:tint="@color/ft_error" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvWorkoutDayName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ft_text_primary"
            android:textSize="21sp"
            android:textStyle="bold"
            tools:text="PUSH" />

        <TextView
            android:id="@+id/tvWorkoutSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/ft_text_secondary"
            android:textSize="14sp"
            tools:text="5 ejercicios · 18 series" />

        <TextView
            android:id="@+id/tvWorkoutDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/ft_surface_alt"
            android:padding="12dp"
            android:textColor="@color/ft_text_primary"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="Press banca&#10;Serie 1: 60 kg · 10 reps · RIR 2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleDetail"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ver detalle"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textStyle="bold"
            app:backgroundTint="@color/fui_transparent"
            app:cornerRadius="14dp"
            app:strokeColor="@color/ft_border"
            app:strokeWidth="1dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>