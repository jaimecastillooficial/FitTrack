<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@color/ft_background"
    android:fillViewport="true"
    tools:context=".ui.MainApp.Workout.WorkoutFragment">



        <TextView
            android:id="@+id/tvWorkoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center"

            android:text="Entrenamiento"
            android:textColor="@color/ft_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="6dp"/>


        <androidx.cardview.widget.CardView
            android:id="@+id/cardWorkoutHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/ft_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvActiveRoutineLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rutina activa"
                    android:textColor="@color/ft_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvActiveRoutineValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    tools:text="Arnold Split"
                    android:textColor="@color/ft_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/ft_border" />

                <TextView
                    android:id="@+id/tvTodayLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy toca"
                    android:textColor="@color/ft_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvTodayValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    tools:text="Brazo + Hombro"
                    android:textColor="@color/ft_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWorkoutMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Crea o activa una rutina para empezar"
                    android:textColor="@color/ft_text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartWorkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:text="Empezar entreno"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:backgroundTint="@color/ft_primary"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMyRoutines"
            app:backgroundTint="@color/fui_transparent"
            android:textColor="@color/black"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Mis rutinas"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:cornerRadius="14dp"
            app:strokeColor="@color/ft_border"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Historial"
            app:backgroundTint="@color/fui_transparent"
            android:textColor="@color/black"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:cornerRadius="14dp"
            app:strokeColor="@color/ft_border"
            app:strokeWidth="1dp" />

    </LinearLayout>
