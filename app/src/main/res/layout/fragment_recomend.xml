<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ft_background"
    tools:context=".ui.Auth.RecomendFragment">



    <!-- CONTENEDOR PRINCIPAL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BARRA DE PROGRESO -->
        <LinearLayout
            android:id="@+id/stepProgressContainer"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:id="@+id/step1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@color/ft_primary" />

            <View
                android:id="@+id/step2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@color/ft_primary" />

            <View
                android:id="@+id/step3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@color/ft_primary" />

            <View
                android:id="@+id/step4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/ft_primary" />
        </LinearLayout>

        <!-- TITULO -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Your_plan"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/ft_text_primary"
            app:layout_constraintTop_toBottomOf="@id/stepProgressContainer"
            app:layout_constraintStart_toEndOf="@id/goBack"
            android:layout_marginTop="14dp"
            android:layout_marginStart="12dp"/>

        <ImageView
            android:id="@+id/goBack"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/back"
            app:layout_constraintEnd_toStartOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stepProgressContainer"
            android:layout_marginTop="10dp"
            />

        <!-- SUBTITULO -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/Text_RecomendedTargets"
            android:textSize="14sp"
            android:textColor="@color/ft_text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"

            app:layout_constraintEnd_toEndOf="parent" />

        <!-- CARD CALORIAS -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCalories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="@color/white"

            app:strokeColor="@color/ft_primary"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvCaloriesLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recomended_calories"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ft_text_primary" />

                <TextView
                    android:id="@+id/tvRecommendedCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    tools:text="2450 kcal"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/ft_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD PESO -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWeight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="@color/white"

            app:strokeColor="@color/ft_primary"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardCalories"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvTargetWeightLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recommended_target_weight"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ft_text_primary" />

                <TextView
                    android:id="@+id/tvRecommendedTargetWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    tools:text="73.5 kg"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/ft_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- INPUT CALORIAS -->
        <TextView
            android:id="@+id/tvCaloriesInputTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/target_calories"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/ft_text_primary"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/cardWeight"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/caloriesGoalLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:boxStrokeColor="@color/ft_primary"
            app:layout_constraintTop_toBottomOf="@id/tvCaloriesInputTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtCaloriesGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/ft_text_primary"
                tools:text="2450"
                android:hint="@string/calories_per_day" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- INPUT PESO OBJETIVO -->
        <TextView
            android:id="@+id/tvTargetWeightInputTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/peso_objetivo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/ft_text_primary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/caloriesGoalLayout"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/targetWeightLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:boxStrokeColor="@color/ft_primary"
            app:layout_constraintTop_toBottomOf="@id/tvTargetWeightInputTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtTargetWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/ft_text_primary"
                tools:text="73.5"
                android:hint="@string/target_weight_en_kg" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- BOTON FINAL -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/finish"
            android:textColor="@color/white"
            android:backgroundTint="@color/btn_signupmodule_background_validations"
            app:cornerRadius="16dp"
            android:layout_marginTop="26dp"
            app:layout_constraintTop_toBottomOf="@id/targetWeightLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>