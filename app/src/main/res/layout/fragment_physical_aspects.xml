<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ft_background"
    android:padding="24dp"
    tools:context=".ui.Auth.PhysicalAspectsFragment">

    <LinearLayout
        android:id="@+id/stepProgressContainer"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:orientation="horizontal"

        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/step1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@color/ft_primary"/>

        <View
            android:id="@+id/step2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@color/ft_primary"/>

        <View
            android:id="@+id/step3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/ft_primary"/>

        <View
            android:id="@+id/step4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@color/ft_border"/>
    </LinearLayout>

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Physical_Aspects"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/ft_text_primary"
        app:layout_constraintTop_toBottomOf="@id/stepProgressContainer"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- GENDER LABEL -->
    <TextView
        android:id="@+id/tvGender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Sex"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/ft_text_primary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- SEGMENTED CONTROL -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/genderToggle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/tvGender"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMale"
            style="@style/FitTrackSegmentButton"

            android:fontFamily="sans-serif"
            android:text="@string/Male" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFemale"
            style="@style/FitTrackSegmentButton"
            android:fontFamily="sans-serif"
            android:text="@string/Female"/>

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- AGE LABEL -->
    <TextView
        android:id="@+id/tvAge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/How_old_are_you"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/ft_text_primary"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/genderToggle"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- AGE INPUT -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/ageLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:boxStrokeColor="@color/ft_primary"
        app:layout_constraintTop_toBottomOf="@id/tvAge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/txtAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/ft_text_primary"

            android:hint="@string/Age"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- HEIGHT LABEL -->
    <TextView
        android:id="@+id/tvHeight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/How_tall_are_you"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/ft_text_primary"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/ageLayout"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- HEIGHT INPUT -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/heightLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:boxStrokeColor="@color/ft_primary"
        app:layout_constraintTop_toBottomOf="@id/tvHeight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/txtHeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/ft_text_primary"
            android:hint="@string/Height"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- HEIGHT LABEL -->
    <TextView
        android:id="@+id/tvWeight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/How_much_do_you_weight"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/ft_text_primary"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/heightLayout"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- HEIGHT INPUT -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/weightLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:boxStrokeColor="@color/ft_primary"
        app:layout_constraintTop_toBottomOf="@id/tvWeight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/txtWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/ft_text_primary"
            android:hint="@string/Weight"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- CONTINUE BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/Next"
        android:textColor="@color/white"
        android:backgroundTint="@color/ft_primary"
        app:cornerRadius="16dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/weightLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>